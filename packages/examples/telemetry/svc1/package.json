{
  "name": "telemetry-svc1",
  "version": "0.0.6",
  "private": true,
  "author": "Nicola Bovolato",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node --require ./dist/instrumentation.js dist/index.js",
    "dev": "HTTP_PORT=8080 SVC2_URL=http://127.0.0.0:8081 tsx watch --require tsx/cjs --require ./src/instrumentation.mts --inspect src/index.ts | pino-pretty -c -t",
    "build": "tsup-node src/index.ts src/instrumentation.ts",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@basica/config": "workspace:^0.0.4",
    "@basica/core": "workspace:^0.0.5",
    "@basica/fastify": "workspace:^0.1.2",
    "@basica/telemetry": "workspace:^0.0.3",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.220.0",
    "fastify": "^5.10.0",
    "opentelemetry-instrumentation-fetch-node": "^1.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@basica/eslint-config": "workspace:^0.0.0",
    "@basica/typescript-config": "workspace:^0.0.0",
    "@types/node": "^24.13.3",
    "eslint": "^10.7.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
