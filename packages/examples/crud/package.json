{
  "name": "crud",
  "version": "0.0.7",
  "private": true,
  "author": "Nicola Bovolato",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node dist/src/index.js",
    "dev": "DB_CONNECTIONTIMEOUTMILLIS=1000 DB_CONNECTIONSTRING=postgres://postgres:postgres@localhost:5432/postgres tsx watch --inspect src/index.ts | pino-pretty -c -t",
    "build": "tsup-node src/index.ts migrations/*.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "lint": "tsc --noEmit && eslint \"{src,test,migrations}/**/*.ts\""
  },
  "dependencies": {
    "@basica/config": "workspace:^0.0.4",
    "@basica/core": "workspace:^0.0.5",
    "@basica/fastify": "workspace:^0.1.2",
    "@basica/kysely": "workspace:^0.0.5",
    "@basica/pg": "workspace:^0.0.6",
    "@fastify/type-provider-typebox": "^5.0.1",
    "@sinclair/typebox": "^0.32.16",
    "fastify": "^5.0.0",
    "kysely": "^0.27.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@basica/eslint-config": "workspace:^0.0.0",
    "@basica/typescript-config": "workspace:^0.0.0",
    "@basica/vitest-config": "workspace:^0.0.0",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
