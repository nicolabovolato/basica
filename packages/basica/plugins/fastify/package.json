{
  "name": "@basica/fastify",
  "version": "0.1.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolabovolato/basica.git",
    "directory": "packages/basica/plugins/fastify"
  },
  "author": "Nicola Bovolato",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup-node",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration",
    "lint": "tsc --noEmit && eslint \"{src,test}/**/*.ts\""
  },
  "dependencies": {
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@basica/core": "workspace:^0.0.7",
    "fastify": ">=5.6.0 <6.0.0"
  },
  "devDependencies": {
    "@basica/core": "workspace:^0.0.7",
    "@basica/eslint-config": "workspace:^0.0.0",
    "@basica/tsup-config": "workspace:^0.0.0",
    "@basica/typescript-config": "workspace:^0.0.0",
    "@basica/vitest-config": "workspace:^0.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "undici": "^8.7.0",
    "vitest": "^4.1.10"
  }
}
